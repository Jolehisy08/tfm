<launch>
  <param name="/use_sim_time" value="true" />


  <!-- Convert 3D point cloud from Velodyne to 2D laser scan for Gmapping -->
  <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">
      <remap from="cloud_in" to="/velodyne_points"/>
      <remap from="scan" to="/scan_from_3d"/>
      <rosparam>
          target_frame: velodyne  transform_tolerance: 0.01
          min_height: 0.0
          max_height: 1.0  angle_min: -3.141516
          angle_max: 3.141516
          angle_increment: 0.0087
          scan_time: 0.1
          range_min: 0.2
          range_max: 100.0
          use_inf: true
          inf_epsilon: 1.0
          concurrency_level: 1
      </rosparam>
  </node>

  <!-- Gmapping SLAM node -->
  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <param name="base_frame" value="base_link"/>
    <param name="odom_frame" value="odom"/>
    <param name="map_frame"  value="map"/>

    <param name="xmin"  value="-50"/>
    <param name="ymin"  value="-50"/>
    <param name="xmax"  value="50"/>
    <param name="ymax"  value="50"/>
    <param name="delta" value="0.05"/>

    <param name="maxUrange" value="90"/>
    <param name="maxRange"  value="100"/>
    <param name="map_update_interval" value="1.0"/>
    
    <param name="particles" value="1"/> 
    
    <remap from="scan" to="/scan_from_3d"/>
  </node>

  <arg name="map_file" value="$(find pioneer_tfm)/data/mapa_ull_clean.pcd" />

  <!-- HDL Localization nodelets -->
  <node pkg="nodelet" type="nodelet" name="velodyne_nodelet_manager" args="manager" output="screen"/>
  
  <node pkg="nodelet" type="nodelet" name="globalmap_server_nodelet" args="load hdl_localization/GlobalmapServerNodelet velodyne_nodelet_manager">
      <param name="globalmap_pcd" value="$(arg map_file)" />
      <param name="convert_utm_to_local" value="true" />
      <param name="downsample_resolution" value="0.1" />
  </node>

  <!-- Localization nodelet using NDT -->
  <node pkg="nodelet" type="nodelet" name="hdl_localization_nodelet" args="load hdl_localization/HdlLocalizationNodelet velodyne_nodelet_manager">
      <remap from="/velodyne_points" to="/velodyne_points" />
      
      <param name="odom_child_frame_id" value="base_link" />
      <param name="map_frame_id" value="odom" />

      <param name="use_imu" value="false" />
      <param name="enable_robot_odometry_prediction" value="false" />

      <param name="reg_method" value="NDT_OMP" />
      <param name="ndt_neighbor_search_method" value="DIRECT7" />
      <param name="ndt_neighbor_search_radius" value="2.0" />
      <param name="ndt_resolution" value="1.0" />
      <param name="downsample_resolution" value="0.1" />

      <param name="specify_init_pose" value="true" />
      <param name="init_pos_x" value="0.0" />
      <param name="init_pos_y" value="0.0" />
      <param name="init_pos_z" value="0.0" />
  </node>
</launch>




