<launch>
<node pkg="tf2_ros" type="static_transform_publisher" name="base_to_pioneer" args="0 0 0 0 0 0 base_link base_link_pioneer" />
<node pkg="tf2_ros" type="static_transform_publisher" name="base2velodyne" args="0.185 0 0.78 0.0 0.0 0.0 base_link velodyne" />

<node pkg="tf2_ros" type="static_transform_publisher" name="base2imu" args="0.185 0 0.0 0.0 0.0 0.0 base_link imu_link" />

<node pkg="tf2_ros" type="static_transform_publisher" name="base2pearl" args="0.25  0 0.335 3.14152 -1.62 0.1 base_link rslidar" />

   <!-- node pkg="sensor_filters" type="pointcloud2_filter_chain" output="screen" name="pointcloud2_filters">
        <remap from="~input" to="/rsHelios_points" />
        <remap from="~output" to="/rsHelios_filtered" />
        
        <rosparam command="load" file="$(find pioneer_launch)/launch/navegacionstvl/filter_tf_config.yaml" />
        
    </node-->

</launch>
