<launch>
    
    <!--Use simulated time for all nodes to synchronize with the bag file playback-->
    <param name="/use_sim_time" value="true" />

    <!--Include the bring-up launch file to start the Pioneer robot and its sensors-->
    <!--include file="$(find pioneer)/launch/bring_upv2.launch" /-->

    <!--Include the TF configuration for the Pioneer robot-->
    <include file="$(find pioneer)/launch/pioneer_tf.launch" />

    <!--Load the robot description from the xacro file-->
    <param name="robot_description" command="$(find xacro)/xacro --inorder $(find p2os_urdf)/defs/pioneer3at.xacro" />

    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen" />

    <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher">
        <param name="use_gui" value="false"/>
    </node>
    
    <!--Load the odometry reconstruction node to generate odometry data from encoder readings-->
    <node pkg="pioneer" type="OdomGenerada.py" name="odom_reconstruct" output="screen">
        <param name="base_link_frame" value="base_link"/>
        <param name="odom_frame" value="odom"/>
    </node>

    <!--Convert Velodyne point cloud to laser scan for gmapping -->
    <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">
        <remap from="cloud_in" to="/velodyne_points"/>
        <remap from="scan" to="/scan"/>
        <rosparam>
            target_frame: base_link 
            min_height: 0.2  
            max_height: 1.0  
            angle_min: -3.141592653
            angle_max: 3.141592653
            angle_increment: 0.0087
            scan_time: 0.1
            range_min: 0.1
            range_max: 50.0
            use_inf: true
        </rosparam>
    </node>

    <!--Include the SLAM node using GMapping-->
    <include file="$(find pioneer)/launch/slam_gmapping_pioneer.launch" />

    <node pkg="rosbag" type="play" name="player" args="--clock /home/jolehisy/tfm_datos/bags/pioneer_2026-02-05-11-24-40.bag" />  

    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find pioneer)/rviz/gmapping_pioneer.rviz" />
</launch>