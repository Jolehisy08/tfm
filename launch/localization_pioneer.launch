<launch>
    <param name="/use_sim_time" value="true" />

    <node pkg="tf" type="static_transform_publisher" name="lidar2base" args="0.185 0 0.75 0 0 0 base_link velodyne 100"/>

    <include file="$(find pioneer)/launch/hdl_localization_pioneer.launch" />

    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find pioneer)/rviz/localization_pioneer.rviz" />

    <node pkg="rosbag" type="play" name="player" args="--clock /home/jolehisy/tfm_datos/bags/pioneer_2026-02-05-11-24-40.bag" />

</launch>