<launch>
    <param name="/use_sim_time" value="true"/>
    <env name="GAZEBO_MODEL_PATH" value="$(find pioneer)/gazebo/models:$(optenv GAZEBO_MODEL_PATH)"/>

    <include file="$(find gazebo_ros)/launch/empty_world.launch">
        <arg name="world_name" value="$(find pioneer)/gazebo/worlds/facultad_gazebo.world"/>
        <arg name="paused" value="false"/>
        <arg name="gui" value="true"/>
    </include>

    <param name="robot_description" command="$(find xacro)/xacro '$(find p2os_urdf)/defs/pioneer3at.xacro'" />
    
    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />
    <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher" />

    <node name="urdf_spawner" pkg="gazebo_ros" type="spawn_model" respawn="false" output="screen"
          args="-urdf -model pioneer -param robot_description -x 0 -y 0 -z 0.05"/>

    <node name="map_server" pkg="map_server" type="map_server" args="$(find pioneer)/gazebo/config/maps/mapa_facultad_stage.yaml" />

    <include file="$(find pioneer)/launch/hdl_localization_pioneer.launch" >
        <arg name="map_file" value="$(find pioneer)/data/mapa_ull_clean.pcd" />
        <arg name="odom_child_frame_id" value="base_link" />
    </include>

    <node pkg="pioneer" type="OdomGenerada.py" name="odom_reconstruct" output="screen">
        <param name="base_link_frame" value="base_link"/>
        <param name="odom_frame" value="odom"/>
    </node>

    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
        <rosparam file="$(find pioneer)/gazebo/config/costmap_common_params.yaml" command="load" ns="global_costmap" /> 
        <rosparam file="$(find pioneer)/gazebo/config/costmap_common_params.yaml" command="load" ns="local_costmap" />
        <rosparam file="$(find pioneer)/gazebo/config/local_costmap_params.yaml" command="load" />
        <rosparam file="$(find pioneer)/gazebo/config/global_costmap_params.yaml" command="load" /> 
        <rosparam file="$(find pioneer)/gazebo/config/base_local_planner_params.yaml" command="load" />
        <remap from="cmd_vel" to="/cmd_vel"/>
    </node>

    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find pioneer)/navigationStage/rviz/costmap.rviz" />
</launch>