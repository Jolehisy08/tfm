<launch>
  <node name="map_server" pkg="map_server" type="map_server" args="$(find pioneer_tfm)/data/mapa_facultad_2dHDL.yaml" />

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS"/>
    <remap from="odom" to="/odometry/filtered" />
    
    <rosparam file="$(find pioneer_tfm)/navigationSTVL-Ramp-TEB/config/costmap_common_params_pioneer.yaml" command="load" ns="global_costmap" /> 
    <rosparam file="$(find pioneer_tfm)/navigationSTVL-Ramp-TEB/config/costmap_common_params_pioneer.yaml" command="load" ns="local_costmap" />
    
    <rosparam file="$(find pioneer_tfm)/navigationSTVL-Ramp-TEB/config/local_costmap_params_pioneer.yaml" command="load" />
    
    <rosparam file="$(find pioneer_tfm)/navigationSTVL-Ramp-TEB/config/global_costmap_params_pioneer.yaml" command="load" /> 
    
    <rosparam file="$(find pioneer_tfm)/navigationSTVL-Ramp-TEB/config/teb_local_planner_params.yaml" command="load" />
    
    <param name="controller_frequency" value="5.0" />

  </node>
</launch>
