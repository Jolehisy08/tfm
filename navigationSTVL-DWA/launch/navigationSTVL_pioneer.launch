<launch>

    <include file="$(find pioneer)/launch/localization_pioneer.launch" />

    <node name="map_server_2d" pkg="map_server" type="map_server" args="$(find pioneer_tfm)/data/mapa_facultad_2d.yaml" />

    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
        <rosparam file="$(find pioneer)/navigationSTVL/config/costmap_common_params_pioneer.yaml" command="load" ns="global_costmap" />
        <rosparam file="$(find pioneer)/navigationSTVL/config/costmap_common_params_pioneer.yaml" command="load" ns="local_costmap" />
        <rosparam file="$(find pioneer)/navigationSTVL/config/local_costmap_params_pioneer.yaml" command="load" />
        <rosparam file="$(find pioneer)/navigationSTVL/config/global_costmap_params_pioneer.yaml" command="load" />
        <rosparam file="$(find pioneer)/navigationSTVL/config/dwa_local_planner_params.yaml" command="load" />
    </node>

    <!--Launch RViz with a predefined configuration for visualization-->
    <!--node pkg="rviz" type="rviz" name="rviz" args="-d $(find pioneer)/navigationSTVL/rviz/costmap.rviz" /-->

</launch>
