<launch>
  <node name="map_server" pkg="map_server" type="map_server" args="$(find pioneer_tfm)/data/mapa_facultad_2dHDL.yaml" />

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
    
    <rosparam file="$(find pioneer_tfm)/navigationSTVL-DWA/config/costmap_common_params.yaml" command="load" ns="global_costmap" /> 
    <rosparam file="$(find pioneer_tfm)/navigationSTVL-DWA/config/costmap_common_params.yaml" command="load" ns="local_costmap" />
    
    <rosparam file="$(find pioneer_tfm)/navigationSTVL-DWA/config/local_costmap_params.yaml" command="load" />
    
    <rosparam file="$(find pioneer_tfm)/navigationSTVL-DWA/config/global_costmap_params.yaml" command="load" /> 
    
    <rosparam file="$(find pioneer_tfm)/navigationSTVL-DWA/config/base_local_planner_params.yaml" command="load" />
    
    <param name="controller_frequency" value="5.0" />

  </node>
</launch>
